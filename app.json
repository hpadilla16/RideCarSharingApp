{
  "expo": {
    "name": "Ride Car Sharing",
    "slug": "ride-car-sharing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ridecarsharing",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8752FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ridefleet.carsharing"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8752FE"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ridefleet.carsharing"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "5e652730-2e2e-4d63-aa7e-ba3891fea1a9"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
